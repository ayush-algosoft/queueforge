{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Jobs Submitted / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(queueforge_jobs_submitted_total{outcome=\"accepted\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Jobs Processed / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(queueforge_jobs_processed_total{outcome=\"succeeded\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Dead-lettered (total)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(queueforge_jobs_processed_total{outcome=\"dead_lettered\"})",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Recovered Leases",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "queueforge_recovery_reclaimed_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Queue Depth (non-terminal)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (priority, state) (queueforge_queue_depth{state=~\"pending|queued|running\"})",
          "legendFormat": "{{priority}} / {{state}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Oldest Pending Age (s) by priority",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "queueforge_oldest_pending_age_seconds",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Handler Duration p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(queueforge_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(queueforge_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(queueforge_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 }
    },
    {
      "type": "timeseries",
      "title": "Outcome rate / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(queueforge_jobs_processed_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 }
    }
  ],
  "schemaVersion": 39,
  "tags": ["queueforge"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "",
  "title": "QueueForge Overview",
  "uid": "queueforge-overview",
  "version": 1,
  "weekStart": ""
}
